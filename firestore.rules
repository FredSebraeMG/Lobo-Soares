rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: works
    // Fields: title, description, mediaType, mediaUrl, category, price, externalLink, isActive, createdAt
    //
    // Collection: categories
    // Fields: name, slug
    //
    // Collection: profiles
    // Fields: bio, photoUrl, email, phone, address
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "frederico.arantes@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidWork(data) {
      return data.keys().hasAll(['title', 'mediaType', 'mediaUrl', 'category', 'isActive']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.mediaType in ['text', 'image', 'audio', 'video'] &&
             data.mediaUrl is string &&
             data.category is string &&
             data.isActive is bool;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'slug']) &&
             data.name is string && data.name.size() > 0 &&
             data.slug is string && data.slug.size() > 0;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['bio', 'email']) &&
             data.bio is string &&
             data.email is string;
    }

    // Rules
    match /works/{workId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow create, update, delete: if isAdmin() && isValidWork(request.resource.data);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidCategory(request.resource.data);
    }

    match /profiles/{profileId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProfile(request.resource.data);
    }
  }
}
